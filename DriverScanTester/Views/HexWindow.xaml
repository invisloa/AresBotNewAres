<Window x:Class="DriverScanTester.Views.HexWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hex Viewer" Height="520" Width="980"
        WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <Style TargetType="DataGrid">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
        </Style>
        <Thickness x:Key="Pad4">4</Thickness>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6">
            <TextBlock VerticalAlignment="Center" Text="Address:" Margin="0,0,6,0"/>
            <TextBox Width="160" Text="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Go" Command="{Binding GoCommand}"/>
            <Separator Width="12" />
            <TextBlock VerticalAlignment="Center" Text="Range:" Margin="6,0,4,0"/>
            <TextBox Width="60" Text="{Binding RangeBytes, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock VerticalAlignment="Center" Text="bytes" Margin="4,0,0,0"/>
            <Button Content="-0x10" Command="{Binding CenterMinus0x10Command}" />
            <Button Content="+0x10" Command="{Binding CenterPlus0x10Command}" />
            <Separator Width="12" />
            <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
            <Button Content="Clear" Command="{Binding ClearChangedCommand}" ToolTip="Clear all change highlights"/>
            <CheckBox Margin="12,0,0,0" VerticalAlignment="Center"
                      Content="Auto-refresh" IsChecked="{Binding AutoRefresh}"/>
            <TextBlock VerticalAlignment="Center" Text="every" Margin="6,0,4,0"/>
            <TextBox Width="60" Text="{Binding RefreshMs, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock VerticalAlignment="Center" Text="ms" Margin="4,0,0,0"/>
            <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                       Text="{Binding StatusText}" />
            <Separator Width="12" />
            <TextBlock VerticalAlignment="Center" Text="Selected:" Margin="6,0,4,0"/>
            <TextBox Width="170" Text="{Binding SelectedAddressHex, Mode=OneWay}" IsReadOnly="True" Background="#FFF5F5F5"/>
            <Button Content="Copy Addr" Command="{Binding CopyAddressCommand}" ToolTip="Copy selected address to clipboard"/>
            <Button Content="Copy Row" Command="{Binding CopyRowCommand}" ToolTip="Copy address + hex + ASCII to clipboard"/>
        </StackPanel>

        <!-- Grid -->
        <DataGrid x:Name="HexGrid" ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow, Mode=TwoWay}" CurrentCellChanged="HexGrid_CurrentCellChanged" Margin="6" HeadersVisibility="Column" GridLinesVisibility="Vertical">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding AddressHex}" Header="Address" Width="*" MinWidth="150"/>

                <DataGridTemplateColumn Header="00" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding B00}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding B00EverChanged}" Value="True">
                                                <Setter Property="Background" Value="#FFCCFFCC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="01" Width="36">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding B01}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding B01EverChanged}" Value="True">
                                                <Setter Property="Background" Value="#FFCCFFCC"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

