<Window x:Class="DriverScanTester.Views.MatchesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scan Results"
        Height="500" Width="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <!-- Buttons -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="PointerScanButton"
                    Content="Pointer Scan Selected"
                    Click="PointerScan_Click"
                    Margin="0,0,5,0"
                    Visibility="Collapsed" />
            <Button Content="Copy Selected"
                    Click="CopySelected_Click"
                    Margin="0,0,5,0" />
            <Button Content="Copy All"
                    Click="CopyAll_Click" />
            <Button Content="Close"
                    Click="Close_Click"
                    Margin="10,0,0,0" />
        </StackPanel>

        <!-- List of addresses + current value -->
        <ListView x:Name="AddressListView"
                  FontFamily="Consolas"
                  FontSize="14"
                  SelectionMode="Extended">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Address"
                                    Width="190"
                                    DisplayMemberBinding="{Binding Address}" />
                    <GridViewColumn Header="Value"
                                    Width="120"
                                    DisplayMemberBinding="{Binding Value}" />
                    <GridViewColumn Header="OK"
                                    Width="50"
                                    DisplayMemberBinding="{Binding Ok}" />
                </GridView>
            </ListView.View>
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Tag="PointerScanSelected"
                              Header="Pointer Scan Selected"
                              Click="PointerScan_Click"
                              Visibility="Collapsed"/>
                    <MenuItem Header="Copy Selected" Click="CopySelected_Click"/>
                    <MenuItem Header="Copy All" Click="CopyAll_Click"/>
                    <Separator Tag="PointerScanSeparator" Visibility="Collapsed"/>
                    <MenuItem Tag="PointerScan"
                              Header="Pointer Scan…"
                              Click="PointerScan_Click"
                              Visibility="Collapsed"/>
                </ContextMenu>
            </ListView.ContextMenu>
        </ListView>
    </DockPanel>
</Window>
