<Window x:Class="DriverScanTester.Views.PointerScanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pointer Scan"
        Width="640"
        Height="560"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,6,0">
            <TextBlock Text="Target From" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding TargetAddressText, UpdateSourceTrigger=PropertyChanged}" Width="110" Margin="0,0,6,0"/>
            <TextBlock Text="To" VerticalAlignment="Center" Margin="0,0,6,0"/>
            <TextBox Text="{Binding TargetEndText, UpdateSourceTrigger=PropertyChanged}" Width="110" Margin="0,0,6,0"/>
        </StackPanel>
        
        <Button Grid.Row="0" Grid.Column="2" Content="Suggest ±50MB" Command="{Binding SuggestCommand}" Margin="0,0,6,0" />
        <CheckBox Grid.Row="0" Grid.Column="3" Content="Static only" IsChecked="{Binding ModulesOnly}" VerticalAlignment="Center" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Range" VerticalAlignment="Center" Margin="0,8,6,0"/>
        <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,0">
            <StackPanel.Resources>
                <Style TargetType="TextBox">
                    <Setter Property="Margin" Value="0,0,6,0"/>
                </Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Margin" Value="0,0,6,0"/>
                    <Setter Property="VerticalAlignment" Value="Center"/>
                </Style>
            </StackPanel.Resources>
            
            <ComboBox ItemsSource="{Binding Modules}" SelectedItem="{Binding SelectedModule}" DisplayMemberPath="Name" Width="140" Margin="0,0,6,0"/>
            <Button Content="Set Range" Command="{Binding SetRangeToModuleCommand}" Margin="0,0,12,0" Padding="4,0"/>

            <TextBox Width="140" Text="{Binding RangeStartText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="to"/>
            <TextBox Width="140" Text="{Binding RangeEndText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Alignment"/>
            <TextBox Width="60" Text="{Binding AlignmentText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Max offset"/>
            <TextBox Width="80" Text="{Binding MaxOffsetText, UpdateSourceTrigger=PropertyChanged}"/>
            <TextBlock Text="Max results"/>
            <TextBox Width="60" Text="{Binding MaxResultsText, UpdateSourceTrigger=PropertyChanged}" Margin="0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,8" HorizontalAlignment="Right">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="Margin" Value="0,0,6,0"/>
                </Style>
            </StackPanel.Resources>
            <Button Content="Scan" Command="{Binding ScanCommand}" Width="80"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80"/>
            <Button Content="Resolve Chain" Command="{Binding ResolveChainCommand}" Width="110"/>
            <Button Content="Generate Addresses" Command="{Binding GenerateAddressesCommand}" Width="130"/>
            <Button Content="Copy JSON" Command="{Binding CopyChainCommand}" Width="100" Margin="0"/>
        </StackPanel>

        <DataGrid x:Name="ResultsGrid" Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="4" 
                  ItemsSource="{Binding Results}" 
                  SelectedItem="{Binding SelectedResult}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Extended"
                  ClipboardCopyMode="ExcludeHeader"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  Background="White"
                  BorderBrush="LightGray"
                  Margin="0,0,0,8"
                  SelectionChanged="ResultsGrid_SelectionChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="FontFamily" Value="Consolas"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGreen}" Value="True">
                            <Setter Property="Foreground" Value="DarkGreen"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Pointer" Binding="{Binding AddressHex}" Width="160"/>
                <DataGridTextColumn Header="Depth" Binding="{Binding Depth}" Width="60"/>
                <DataGridTextColumn Header="Distance" Binding="{Binding DistanceHex}" Width="120"/>
                <DataGridTextColumn Header="Module" Binding="{Binding ModuleName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding StatusMessage}" Foreground="DarkSlateBlue" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding ChainJson, Mode=OneWay}" FontFamily="Consolas" FontSize="12" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>
    </Grid>
</Window>
