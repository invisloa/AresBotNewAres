<Window x:Class="DriverScanTester.Views.PointerScanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pointer Scan"
        Height="500"
        Width="640"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="120" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Target address:" VerticalAlignment="Center" />
            <TextBox x:Name="TargetAddressTextBox"
                     Grid.Column="1"
                     Margin="6,0,0,0"
                     IsReadOnly="True"
                     FontFamily="Consolas" />
            <TextBlock Grid.Column="3"
                       Text="Alignment:" 
                       VerticalAlignment="Center" />
            <TextBox x:Name="AlignmentTextBox"
                     Grid.Column="4"
                     Margin="6,0,0,0"
                     Width="80"
                     HorizontalContentAlignment="Right" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Range start:" VerticalAlignment="Center" />
            <TextBox x:Name="RangeStartTextBox"
                     Grid.Column="1"
                     Margin="6,0,0,0"
                     FontFamily="Consolas" />
            <TextBlock Grid.Column="3"
                       Text="Range end:" 
                       VerticalAlignment="Center" />
            <TextBox x:Name="RangeEndTextBox"
                     Grid.Column="4"
                     Margin="6,0,0,0"
                     FontFamily="Consolas" />
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="SuggestButton"
                    Content="Suggest ±50 MB"
                    Width="140"
                    Click="SuggestButton_Click" />
            <CheckBox x:Name="GreenOnlyCheckBox"
                      Content="Green only (modules)"
                      Margin="12,0,0,0"
                      Checked="GreenOnlyCheckBox_Changed"
                      Unchecked="GreenOnlyCheckBox_Changed" />
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,0,0,6"
                   Text="Configure the scan options and click Scan."
                   TextWrapping="Wrap" />

        <DataGrid x:Name="ResultsGrid"
                  Grid.Row="4"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  SelectionChanged="ResultsGrid_SelectionChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="Black" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGreen}" Value="True">
                            <Setter Property="Foreground" Value="Green" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Pointer Addr"
                                    Binding="{Binding PointerAddressDisplay}"
                                    Width="*" />
                <DataGridTextColumn Header="Module"
                                    Binding="{Binding ModuleDisplay}"
                                    Width="160" />
                <DataGridTextColumn Header="Distance"
                                    Binding="{Binding DistanceDisplay}"
                                    Width="120" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="ScanButton"
                    Width="90"
                    Content="Scan"
                    IsDefault="True"
                    Click="ScanButton_Click" />
            <Button x:Name="UseSelectedButton"
                    Width="110"
                    Margin="8,0,0,0"
                    Content="Use Selected"
                    IsEnabled="False"
                    Click="UseSelectedButton_Click" />
            <Button Width="80"
                    Margin="8,0,0,0"
                    Content="Close"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Window>
