<Window x:Class="DriverScanTester.Views.CameraCalibrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Camera Calibration (Bearing → Game Angle)"
        Height="900" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Live camera angle -->
            <RowDefinition Height="Auto"/>  <!-- Capture buttons -->
            <RowDefinition Height="Auto"/>  <!-- Cardinal textboxes -->
            <RowDefinition Height="Auto"/>  <!-- Apply buttons -->
            <RowDefinition Height="Auto"/>  <!-- Auto-measurement by movement -->
            <RowDefinition Height="*"/>     <!-- Table -->
            <RowDefinition Height="Auto"/>  <!-- Status + Save/Load/Reset -->
        </Grid.RowDefinitions>

        <!-- Row 0: Live camera angle -->
        <Border Grid.Row="0" BorderBrush="#FF007ACC" BorderThickness="2"
                CornerRadius="4" Padding="8" Margin="0,0,0,8" Background="#FFF0F8FF">
            <WrapPanel Orientation="Horizontal">
                <TextBlock Text="Live camera angle (0x1aa): " FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentCameraAngleText}" FontSize="24" FontWeight="Bold"
                           Foreground="#FF007ACC" VerticalAlignment="Center" MinWidth="80"/>
                <TextBlock Text=" (raw game units)" VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
                <Separator Width="1" Margin="15,2" Background="LightGray"/>
                <TextBlock Text="Polling: " FontWeight="Bold" VerticalAlignment="Center"/>
                <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="3,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Red"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPolling}" Value="True">
                                    <Setter Property="Fill" Value="LimeGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </WrapPanel>
        </Border>

        <!-- Row 1: Capture buttons -->
        <GroupBox Grid.Row="1" Header="1. Capture cardinal directions in-game" Margin="0,0,0,8">
            <WrapPanel Orientation="Horizontal" Margin="5">
                <TextBlock Text="Stand still, face each direction, then click the corresponding button:"
                           VerticalAlignment="Center" Margin="0,0,10,0" FontStyle="Italic"/>
                <Button Content="Capture N (0°)"   Command="{Binding CaptureNorthCommand}"     Width="110" Margin="2" Background="#FFDEFFDE"/>
                <Button Content="Capture E (90°)"  Command="{Binding CaptureEastCommand}"      Width="110" Margin="2"/>
                <Button Content="Capture S (180°)" Command="{Binding CaptureSouthCommand}"     Width="110" Margin="2"/>
                <Button Content="Capture W (270°)" Command="{Binding CaptureWestCommand}"      Width="110" Margin="2"/>
                <Button Content="Capture N2 (360°)" Command="{Binding CaptureNorthFullCommand}" Width="120" Margin="2" ToolTip="Optional: improves full-spin accuracy"/>
            </WrapPanel>
        </GroupBox>

        <!-- Row 2: Cardinal textboxes -->
        <GroupBox Grid.Row="2" Header="2. Cardinal game-angle values (edit by hand if needed)" Margin="0,0,0,8">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="N (0°):"   VerticalAlignment="Center" FontWeight="Bold" Grid.Column="0" Margin="2"/>
                <TextBox Text="{Binding EditableNorth, UpdateSourceTrigger=PropertyChanged}"  Grid.Column="1" Margin="2" VerticalAlignment="Center"/>
                <TextBlock Text="E (90°):"  VerticalAlignment="Center" FontWeight="Bold" Grid.Column="2" Margin="2"/>
                <TextBox Text="{Binding EditableEast, UpdateSourceTrigger=PropertyChanged}"   Grid.Column="3" Margin="2" VerticalAlignment="Center"/>
                <TextBlock Text="S (180°):" VerticalAlignment="Center" FontWeight="Bold" Grid.Column="4" Margin="2"/>
                <TextBox Text="{Binding EditableSouth, UpdateSourceTrigger=PropertyChanged}"  Grid.Column="5" Margin="2" VerticalAlignment="Center"/>
                <TextBlock Text="W (270°):" VerticalAlignment="Center" FontWeight="Bold" Grid.Column="6" Margin="2"/>
                <TextBox Text="{Binding EditableWest, UpdateSourceTrigger=PropertyChanged}"   Grid.Column="7" Margin="2" VerticalAlignment="Center"/>
                <TextBlock Text="N2 (360°):" VerticalAlignment="Center" FontWeight="Bold" Grid.Column="8" Margin="2"/>
                <TextBox Text="{Binding EditableNorthFullCircle, UpdateSourceTrigger=PropertyChanged}" Grid.Column="9" Margin="2" VerticalAlignment="Center"/>
                <TextBlock Text="FullSpin:" VerticalAlignment="Center" FontWeight="Bold" Grid.Column="10" Margin="2"/>
                <TextBox Text="{Binding EditableFullSpin, UpdateSourceTrigger=PropertyChanged}" Grid.Column="11" Margin="2" VerticalAlignment="Center"/>
            </Grid>
        </GroupBox>

        <!-- Row 3: Apply buttons -->
        <GroupBox Grid.Row="3" Header="3. Apply &amp; persist" Margin="0,0,0,8">
            <WrapPanel Orientation="Horizontal" Margin="5">
                <Button Content="Apply cardinals (4-point fit)" Command="{Binding ApplyCardinalsCommand}" Width="180" Margin="2" Background="#FFDEFFDE" FontWeight="Bold"
                        ToolTip="Computes the 9 intermediate points by linear interpolation and updates the live calibration."/>
                <Button Content="Apply full 13-point table" Command="{Binding ApplyFullTableCommand}" Width="180" Margin="2"
                        ToolTip="Use the values currently shown in the table below (auto-filled or hand-edited)."/>
                <Button Content="Auto-fill from cardinals" Command="{Binding AutoFillTableCommand}" Width="160" Margin="2"
                        ToolTip="Recompute intermediate points in the table below without applying yet."/>
                <Separator Width="1" Margin="10,2" Background="LightGray"/>
                <Button Content="Save to file"   Command="{Binding SaveToFileCommand}"      Width="100" Margin="2" Background="#FFFFF0D0" FontWeight="Bold"
                        ToolTip="camera_calibration.json in the bot folder (loaded on next start)."/>
                <Button Content="Load from file" Command="{Binding LoadFromFileCommand}"    Width="100" Margin="2"/>
                <Button Content="Reset to defaults" Command="{Binding ResetToDefaultsCommand}" Width="120" Margin="2" Background="#FFFFD0D0"
                        ToolTip="Restore the hardcoded N/E/S/W values from BotConstants."/>
            </WrapPanel>
        </GroupBox>

        <!-- Row 4: Auto-calibration by movement (no manual aiming needed) -->
        <GroupBox Grid.Row="4" Header="4. Auto-calibration by movement (no manual aiming — RECOMMENDED)" Margin="0,0,0,8" BorderBrush="#FF3399FF" BorderThickness="2">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Margin="5,3" Foreground="#444"
                           Text="Bot faces each direction using the current calibration (even if bad), holds W for 1.5 s, and records (actual walked bearing, game angle). The actual bearing is computed from world-position delta, so it does NOT depend on the bot's bearing math. Click a row to measure one direction, or 'Run all 4' to do N→E→S→W. Bot needs an open flat area (no obstacles) and a focused game window."/>
                <DataGrid ItemsSource="{Binding AutoSamples}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal"
                          Background="White"
                          Height="125"
                          Margin="0,3,0,3">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Direction" Binding="{Binding Label}" Width="90"/>
                        <DataGridTextColumn Header="Asked °" Binding="{Binding RequestedBearingDeg, StringFormat={}{0:F0}}" Width="60"/>
                        <DataGridTemplateColumn Header="Measure" Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Walk"
                                            Command="{Binding DataContext.MeasureOneCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Walked °" Binding="{Binding ActualBearingDeg, StringFormat={}{0:F1}}" Width="65"/>
                        <DataGridTextColumn Header="Game ∠" Binding="{Binding AvgGameAngle, StringFormat={}{0:F0}}" Width="65"/>
                        <DataGridTextColumn Header="N" Binding="{Binding SampleCount}" Width="35"/>
                        <DataGridTextColumn Header="Δdist" Binding="{Binding DistanceTravelled, StringFormat={}{0:F1}}" Width="55"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <WrapPanel Orientation="Horizontal" Margin="0,3,0,0">
                    <Button Content="Run all 4 (N, E, S, W)" Command="{Binding MeasureAllCommand}" Width="180" Margin="2" Background="#FFDEFFDE" FontWeight="Bold"
                            ToolTip="About 6 seconds total. Each pass: face direction, hold W 1.5 s, sample 0x1aa every 50 ms."/>
                    <Button Content="Fit and apply" Command="{Binding FitAndApplyCommand}" Width="120" Margin="2" Background="#FFFFF0D0" FontWeight="Bold"
                            ToolTip="Ordinary least-squares fit: game_angle = scale * bearing + offset. Requires 2+ successful samples."/>
                    <Button Content="Clear samples" Command="{Binding ClearAutoSamplesCommand}" Width="110" Margin="2"/>
                    <TextBlock Text="{Binding FitResultText}" VerticalAlignment="Center" Margin="10,2,2,2" FontStyle="Italic" Foreground="#FF007ACC"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Row 5: 13-point table -->
        <GroupBox Grid.Row="5" Header="5. Calibration table (13 points, 30° apart)" Margin="0,0,0,8">
            <DataGrid ItemsSource="{Binding TableRows}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      IsReadOnly="False"
                      RowHeaderWidth="0"
                      GridLinesVisibility="Horizontal"
                      Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Bearing (°)"
                                        Binding="{Binding BearingDeg, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="100"/>
                    <DataGridTextColumn Header="Game angle (raw, written to 0x1aa)"
                                        Binding="{Binding GameAngleText, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Row 6: Status -->
        <Border Grid.Row="6" BorderBrush="LightGray" BorderThickness="1" CornerRadius="4" Padding="6" Background="#FFF9F9F9">
            <TextBlock Text="{Binding StatusText}" FontStyle="Italic" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</Window>
