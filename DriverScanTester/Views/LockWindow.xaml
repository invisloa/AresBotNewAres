<Page x:Class="DriverScanTester.Views.LockWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:DriverScanTester.ViewModels"
      Title="LockWindow">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8">
            <Button Content="Add address" Command="{Binding AddEntryCommand}" />
            <Button Content="Lock all"   Margin="8,0,0,0" Command="{Binding LockAllCommand}" />
            <Button Content="Unlock all" Margin="8,0,0,0" Command="{Binding UnlockAllCommand}" />
            <Button Content="Save" Margin="8,0,0,0" Command="{Binding SaveEntriesCommand}" />
            <Button Content="Load" Margin="4,0,0,0" Command="{Binding LoadEntriesCommand}" />
            <Border Width="1" Height="20" Background="#CCC" Margin="8,0" />
            <Button Content="Camera" Command="{Binding ToggleCameraGroupCommand}" MinWidth="70">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCameraGroupLocked}" Value="True">
                                <Setter Property="Background" Value="#4CAF50" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Attack" Margin="4,0,0,0" Command="{Binding ToggleAttackGroupCommand}" MinWidth="70">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAttackGroupLocked}" Value="True">
                                <Setter Property="Background" Value="#4CAF50" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Skill" Margin="4,0,0,0" Command="{Binding ToggleSkillGroupCommand}" MinWidth="70">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSkillGroupLocked}" Value="True">
                                <Setter Property="Background" Value="#4CAF50" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Random" Margin="4,0,0,0" Command="{Binding ToggleRandomGroupCommand}" MinWidth="70">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsRandomGroupLocked}" Value="True">
                                <Setter Property="Background" Value="#4CAF50" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- Bulk add panel -->
        <Border Grid.Row="1" Margin="8" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,8">
                    <TextBlock Text="Bulk add addresses (decimal or 0xHEX, one per line):" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                        <Button Content="Add from Text" Command="{Binding AddBulkFromTextCommand}" Margin="0,0,8,0"/>
                        <Button Content="Paste Add" Command="{Binding PasteAndAddBulkCommand}" />
                    </StackPanel>
                </StackPanel>
                <TextBox Text="{Binding BulkInputText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Height="120"
                         FontFamily="Consolas"
                         SpellCheck.IsEnabled="False"/>
            </DockPanel>
        </Border>

        <!-- Main grid -->
        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  IsReadOnly="False"
                  RowHeaderWidth="0"
                  Margin="8">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLocked}" Value="True">
                            <Setter Property="Background" Value="#E8F5E9" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name"
                                    Binding="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*" />

                <!-- Group -->
                <DataGridTemplateColumn Header="Group" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static vm:EnumSources.LockGroups}"
                                      SelectedItem="{Binding LockGroup, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="70" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Address"
                                    Binding="{Binding AddressText, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*" />

                <DataGridTextColumn Header="Resolved"
                                    IsReadOnly="True"
                                    Binding="{Binding ResolvedAddressText}"
                                    Width="1.2*" />

                <!-- Type -->
                <DataGridTemplateColumn Header="Type" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static vm:EnumSources.LockValueTypes}"
                                      SelectedItem="{Binding ValueType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="120" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Priority -->
                <DataGridTemplateColumn Header="Priority" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{x:Static vm:EnumSources.LockPriorities}"
                                      SelectedItem="{Binding Priority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MinWidth="100" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <!-- Current value (read-only live) -->
                <DataGridTextColumn Header="Current"
                                    IsReadOnly="True"
                                    Binding="{Binding CurrentValueText}"
                                    Width="2*" />

                <!-- Desired value -->
                <DataGridTextColumn Header="Value"
                                    Binding="{Binding ValueText, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*" />

                <DataGridTemplateColumn Header="Actions" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="{Binding LockButtonText}"
                                        Command="{Binding ToggleLockCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Remove"
                                        Command="{Binding DataContext.RemoveEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
