<Window x:Class="DriverScanTester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DriverScanTester"
        xmlns:vm="clr-namespace:DriverScanTester.ViewModels"
        mc:Ignorable="d"
        Title="Driver Scan Tester" Height="650" Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Configuration & Session -->
            <RowDefinition Height="Auto"/> <!-- Main Scan Actions -->
            <RowDefinition Height="Auto"/> <!-- Filters & Refinement -->
            <RowDefinition Height="Auto"/> <!-- Tools & Bot -->
            <RowDefinition Height="*"/>    <!-- Log -->
        </Grid.RowDefinitions>

        <!-- Row 0: Session & Configuration -->
        <GroupBox Header="Session &amp; Configuration" Grid.Row="0" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <Label Content="Data Type:" VerticalAlignment="Center"/>
                    <RadioButton Content="Byte" IsChecked="{Binding IsByte}" GroupName="DataType" VerticalAlignment="Center" Margin="5,0"/>
                    <RadioButton Content="Short" IsChecked="{Binding IsShort}" GroupName="DataType" VerticalAlignment="Center" Margin="5,0"/>
                    <RadioButton Content="Int32" IsChecked="{Binding IsCLong}" GroupName="DataType" VerticalAlignment="Center" Margin="5,0"/>
                    <RadioButton Content="Int64" IsChecked="{Binding IsLong}" GroupName="DataType" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <Separator Width="1" Margin="10,2" Background="LightGray"/>

                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <Label Content="PID:" VerticalAlignment="Center"/>
                    <TextBox Width="60" Text="{Binding PidText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <Button Content="Attach" Command="{Binding AttachCommand}" Width="80" Margin="10,0,0,0"/>
                </StackPanel>

                <Separator Width="1" Margin="10,2" Background="LightGray"/>

                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <Label Content="Center addr:" VerticalAlignment="Center"/>
                    <TextBox Width="120" Text="{Binding RangeCenterText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <Label Content="± Range:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox Width="100" Text="{Binding RangeRadiusText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                </StackPanel>
            </WrapPanel>
        </GroupBox>

        <!-- Row 1: Main Scan Actions -->
        <GroupBox Header="Primary Scan" Grid.Row="1" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal">
                <StackPanel Orientation="Horizontal" Margin="5,2">
                    <Label Content="Scan value:" VerticalAlignment="Center"/>
                    <TextBox Width="150" Text="{Binding ValueScanText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" 
                             ToolTip="Enter decimal or 0xHEX"/>
                </StackPanel>
                
                <Button Content="First Scan" Command="{Binding FirstScanCommand}" Width="100" Margin="5,2"/>
                <Button Content="First Scan ≠" Command="{Binding FirstScanNotEqualCommand}" Width="100" Margin="5,2"/>
                <Button Content="Same as Original" Command="{Binding SameAsOriginalCommand}" Width="120" Margin="5,2"/>
                <Button Content="Show Matches" Command="{Binding ShowMatchesCommand}" Width="110" Margin="20,2,5,2" FontWeight="Bold"/>
            </WrapPanel>
        </GroupBox>

        <!-- Row 2: Filters & Refinement -->
        <GroupBox Header="Refinement (Compare vs Last Scan)" Grid.Row="2" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal">
                <Button Content="Increased" Command="{Binding IncreasedCommand}" Width="90" Margin="5,2"/>
                <Button Content="Decreased" Command="{Binding DecreasedCommand}" Width="90" Margin="5,2"/>
                <Button Content="Changed" Command="{Binding ChangedCommand}" Width="90" Margin="5,2"/>
                <Button Content="Not Changed" Command="{Binding NotChangedCommand}" Width="90" Margin="5,2"/>
                <Button Content="Not Equal" Command="{Binding NotEqualCommand}" Width="90" Margin="5,2"/>
                
                <Separator Width="1" Margin="15,2" Background="LightGray"/>
                
                <Button Content="Sub Scan =" Command="{Binding SubScanEqualsCommand}" Width="100" Margin="5,2" ToolTip="Equal to Scan Value"/>
                <Button Content="Sub Scan ≠" Command="{Binding SubScanNotEqualsCommand}" Width="100" Margin="5,2" ToolTip="Not Equal to Scan Value"/>
                
                <Separator Width="1" Margin="15,2" Background="LightGray"/>
                
                <Label Content="Extra1:" VerticalAlignment="Center"/>
                <TextBox Width="80" Text="{Binding SubScan1Text, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                <Button Content="Sub1 =" Command="{Binding SubScan1Command}" Width="75" Margin="3,2" ToolTip="Sub scan using Extra1 value"/>
                <Label Content="Extra2:" VerticalAlignment="Center" Margin="5,0,0,0"/>
                <TextBox Width="80" Text="{Binding SubScan2Text, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                <Button Content="Sub2 =" Command="{Binding SubScan2Command}" Width="75" Margin="3,2" ToolTip="Sub scan using Extra2 value"/>
            </WrapPanel>
        </GroupBox>

        <!-- Row 3: Tools & Bot -->
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <GroupBox Header="Tools" Grid.Column="0" Margin="0,0,5,0">
                <WrapPanel Orientation="Horizontal">
                    <Button Content="Search Address" Command="{Binding ShowSearchAddressCommand}" Width="100" Margin="5,2" Background="#FFF0F0FF"/>
                    <Button Content="Lock Window" Command="{Binding ShowLockWindowCommand}" Width="100" Margin="5,2"/>
                    <Button Content="Hex Window" Command="{Binding ShowHexWindowCommand}" Width="100" Margin="5,2"/>
                    <Button Content="Path Editor" Command="{Binding OpenPathEditorCommand}" Width="100" Margin="5,2" Background="#FFF0F0FF"/>
                    <Button Content="Bot Window" Command="{Binding OpenBotWindowCommand}" Width="100" Margin="5,2" Background="#FFFFF0D0" FontWeight="Bold"/>
                    <Button Content="Camera Calibration" Command="{Binding ShowCameraCalibrationCommand}" Width="130" Margin="5,2" Background="#FFE0FFE0"
                            ToolTip="Re-measure the 4 cardinal directions (N/E/S/W) so the bot picks the right camera angle for any target."/>
                    
                    <Separator Width="1" Margin="15,2" Background="LightGray"/>
                    
                    <Label Content="Pointer Target:" VerticalAlignment="Center"/>
                    <TextBox Width="120" Text="{Binding PointerTargetText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                    <Button Content="Pointer Scan…" Command="{Binding PointerScanCommand}" Width="110" Margin="5,2"/>
                </WrapPanel>
            </GroupBox>

            <GroupBox Header="Bot Actions" Grid.Column="1" Margin="5,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Button Content="Open Bot Window" Command="{Binding OpenBotWindowCommand}" Width="150" Margin="5,2" Background="#FFFFF0D0" FontWeight="Bold"/>
                    <Label Content="(all bot controls)" VerticalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
                </StackPanel>
            </GroupBox>
        </Grid>

        <!-- Row 4: Log output -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button Content="Clear Log" Command="{Binding ClearLogCommand}"
                    HorizontalAlignment="Right" Padding="6,1" FontSize="10" Margin="0,0,0,2" Cursor="Hand"/>
            <TextBox x:Name="LogBox"
                     Grid.Row="1"
                     Text="{Binding LogText, Mode=OneWay}"
                     IsReadOnly="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="11"
                     Background="#FFF9F9F9"
                     TextChanged="LogBox_TextChanged"/>
        </Grid>
    </Grid>
</Window>